# Runtime
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Observability
LOG_LEVEL=INFO

# API metadata
APP_VERSION=1.0.0

# Datadog webhook authentication. Set at least DATADOG_WEBHOOK_TOKEN.
DATADOG_WEBHOOK_TOKEN=replace-with-a-long-random-secret
# Optional: HMAC SHA-256 secret; Datadog must send its signature in X-Datadog-Signature.
# DATADOG_WEBHOOK_HMAC_SECRET=

# Slack Bot API integration. The bot needs chat:write permission and must join the channel.
SLACK_BOT_TOKEN=xoxb-replace-with-your-bot-token
SLACK_INCIDENT_CHANNEL=C0123456789

# GitHub remediation pull requests
GITHUB_TOKEN=github_pat_replace_with_token
GITHUB_REPOSITORY=organization/repository
GITHUB_BASE_BRANCH=main

# Kubernetes action and verification configuration
KUBERNETES_IN_CLUSTER=false
REMEDIATION_WAIT_SECONDS=30
# Explicitly enable execution only after validating rules and least-privilege credentials.
AUTO_REMEDIATION_ENABLED=false

# HTTP middleware
CORS_ALLOW_ORIGINS=*

# Kubernetes investigation connector
KUBECTL_PATH=kubectl
KUBECTL_TIMEOUT_SECONDS=20
